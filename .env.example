# HuggingFace (모델 다운로드/업로드)
HF_TOKEN=

# 국가법령정보 OpenAPI (open.law.go.kr OC)
# 실 다법령 수집에 필요. 키가 없으면 scripts/data/fetch_law.py --smoke 만 실행된다.
LAW_API_KEY=

# OpenDART (선택, 공시 코퍼스 확장용)
DART_API_KEY=

# 실험 추적 (선택)
WANDB_API_KEY=
WANDB_PROJECT=nova-llm

# 캐시/경로 — F 드라이브에 유지 (C 시스템 드라이브 오염 방지)
HF_HOME=F:\nova-llm\models\.hf_cache
HF_HUB_ENABLE_HF_TRANSFER=1
